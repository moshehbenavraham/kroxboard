# OpenClaw Dashboard security and deployment settings

# Primary remote access path
DASHBOARD_HOST=board.aiwithapex.com
# Comma-separated allowlist for Cloudflare Access-authenticated operators.
DASHBOARD_ALLOWED_EMAILS=moshehwebservices@live.com
# Remote requests must arrive through Cloudflare Access. Localhost remains
# the only trusted non-Cloudflare development path.
DASHBOARD_CF_ACCESS_ENABLED=true
DASHBOARD_CF_ACCESS_OTP_PRIMARY=true
# Keep the Cloudflare Access browser session bounded for operator use.
DASHBOARD_CF_ACCESS_SESSION_HOURS=24

# Optional Cloudflare Access JWT validation
# Set this when the app validates the CF Access JWT assertion directly.
DASHBOARD_CF_ACCESS_AUD=replace-with-cloudflare-access-aud
DASHBOARD_CF_ACCESS_EMAIL_HEADER=CF-Access-Authenticated-User-Email
DASHBOARD_CF_ACCESS_JWT_HEADER=CF-Access-Jwt-Assertion

# Second layer for sensitive routes
# Sensitive routes require a second in-app operator challenge before the
# dashboard will allow writes, provider probes, or outbound diagnostics.
DASHBOARD_OPERATOR_CODE_REQUIRED=true
# Use a long random value and keep it server-only.
DASHBOARD_OPERATOR_CODE=replace-with-long-random-operator-code
# Use at least 32 random characters. The dashboard signs an HTTP-only cookie
# from this value and never sends it to the browser runtime.
DASHBOARD_OPERATOR_COOKIE_SECRET=replace-with-32-byte-random-secret
# Must stay at 12 hours or less.
DASHBOARD_OPERATOR_SESSION_HOURS=12

# Sensitive feature flags
ENABLE_MODEL_MUTATIONS=false
ENABLE_ALERT_WRITES=false
ENABLE_PIXEL_OFFICE_WRITES=false
ENABLE_PROVIDER_PROBES=false
ENABLE_OUTBOUND_TESTS=false
ENABLE_LIVE_SEND_DIAGNOSTICS=false
